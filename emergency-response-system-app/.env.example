# The app runs in demo mode without these values.
# Add real database values only when you want to connect Supabase/Postgres.

# Recommended cloud database: Supabase Postgres
# Project URL and anon key are used by browser-side Supabase features.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-side Postgres connection used by src/lib/db.js.
# For Supabase, use the database connection details from Project Settings > Database.
PG_CONNECTION_STRING=
PG_HOST=
PG_PORT=5432
PG_DATABASE=postgres
PG_USER=postgres
PG_PASSWORD=
PG_SSL=true

# Set to "true" when you want to force local dummy data even if PG_HOST exists.
NEXT_PUBLIC_DEMO_MODE=true
